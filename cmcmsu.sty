% cmcmsu.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cmcmsu}[2026/03/01 CMC MSU beamer theme]

% 1) Forward package options to internal option module
\DeclareOption*{%
  \PassOptionsToPackage{\CurrentOption}{cmcmsu-options}%
}
\ProcessOptions\relax

% Load internal modules from sty/
\RequirePackageWithOptions{sty/cmcmsu-options}
\RequirePackage{sty/cmcmsu-fonts}
\RequirePackage{sty/cmcmsu-colors}
\RequirePackage{sty/cmcmsu-beamer}
\RequirePackage{sty/cmcmsu-title}
\RequirePackage{sty/cmcmsu-sections}
\RequirePackage{sty/cmcmsu-environment}
