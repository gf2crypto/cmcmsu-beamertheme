% sty/cmcmsu-tcb.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{sty/cmcmsu-environment}[2026/03/01 cmcmsu theorems and blocks]

\RequirePackage{sty/cmcmsu-options}
\RequirePackage{sty/cmcmsu-colors}


\AtBeginEnvironment{definition}{
    \setbeamercolor{block title}{fg=cmcmsuGreen, bg=cmcmsuGreen!20}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuGreen!10}
    \addtobeamertemplate{block begin}{}{
    \setbeamercolor{itemize item}{fg=cmcmsuGreen}%
    \setbeamercolor{itemize subitem}{fg=cmcmsuGreen}%
    \setbeamercolor{itemize subsubitem}{fg=cmcmsuGreen}%
    \setbeamercolor{enumerate item}{fg=cmcmsuGreen}%
    \setbeamercolor{enumerate subitem}{fg=cmcmsuGreen}%
    \setbeamercolor{enumerate subsubitem}{fg=cmcmsuGreen}%
  }
}

\AtBeginEnvironment{definition*}{
    \setbeamercolor{block title}{fg=cmcmsuGreen, bg=cmcmsuGreen!20}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuGreen!10}
    \setbeamercolor{itemize item}{fg=cmcmsuGreen}%
    \setbeamercolor{itemize subitem}{fg=cmcmsuGreen}%
    \setbeamercolor{itemize subsubitem}{fg=cmcmsuGreen}%
    \setbeamercolor{enumerate item}{fg=cmcmsuGreen}%
    \setbeamercolor{enumerate subitem}{fg=cmcmsuGreen}%
    \setbeamercolor{enumerate subsubitem}{fg=cmcmsuGreen}%
}

\AtBeginEnvironment{theorem}{
    \setbeamercolor{block title}{fg=cmcmsuBlue, bg=cmcmsuBlue!20}
    \setbeamerfont{block body}{shape=\upshape}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuBlue!10}
}

\AtBeginEnvironment{theorem*}{
    \setbeamercolor{block title}{fg=cmcmsuBlue, bg=cmcmsuBlue!20}
    \setbeamerfont{block body}{shape=\upshape}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuBlue!10}
}

\AtBeginEnvironment{lemma}{
    \setbeamercolor{block title}{fg=cmcmsuBlue, bg=cmcmsuBlue!20}
    \setbeamerfont{block body}{shape=\upshape}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuBlue!10}
}
\AtBeginEnvironment{lemma*}{
    \setbeamercolor{block title}{fg=cmcmsuBlue, bg=cmcmsuBlue!20}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuBlue!10}
}

\AtBeginEnvironment{corollary}{
    \setbeamercolor{block title}{fg=cmcmsuBlue, bg=cmcmsuBlue!20}
    \setbeamerfont{block body}{shape=\upshape}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuBlue!10}
}
\AtBeginEnvironment{corollary*}{
    \setbeamercolor{block title}{fg=cmcmsuBlue, bg=cmcmsuBlue!20}
    \setbeamerfont{block body}{shape=\upshape}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuBlue!10}
}


\AtBeginEnvironment{proof}{
    \setbeamercolor{block title}{fg=structure.fg, bg=white}
    \setbeamercolor{block body}{fg=black, bg=white}
    \addtobeamertemplate{block begin}{}{
    \setbeamercolor{itemize item}{fg=structure.fg}%
    \setbeamercolor{itemize subitem}{fg=structure.fg}%
    \setbeamercolor{itemize subsubitem}{fg=structure.fg}%
    \setbeamercolor{enumerate item}{fg=structure.fg}%
    \setbeamercolor{enumerate subitem}{fg=structure.fg}%
    \setbeamercolor{enumerate subsubitem}{fg=structure.fg}%
  }
}


\AtBeginEnvironment{example}{
  \setbeamercolor{block title example}{fg=cmcmsuPurple, bg=cmcmsuPurple!20}
    \setbeamercolor{block body example}{fg=black, bg=cmcmsuPurple!10}
  \addtobeamertemplate{block example begin}{}{
    \setbeamercolor{itemize item}{fg=cmcmsuPurple}%
    \setbeamercolor{itemize subitem}{fg=cmcmsuPurple}%
    \setbeamercolor{itemize subsubitem}{fg=cmcmsuPurple}%
    \setbeamercolor{enumerate item}{fg=cmcmsuPurple}%
    \setbeamercolor{enumerate subitem}{fg=cmcmsuPurple}%
    \setbeamercolor{enumerate subsubitem}{fg=cmcmsuPurple}%
  }
}

\AtBeginEnvironment{fact}{
    \setbeamercolor{block title}{fg=white, bg=cmcmsuRed}
    \setbeamercolor{block body}{fg=black, bg=cmcmsuRed!10}
    \setbeamercolor{itemize item}{fg=cmcmsuRed}%
    \setbeamercolor{itemize subitem}{fg=cmcmsuRed}%
    \setbeamercolor{itemize subsubitem}{fg=cmcmsuRed}%
    \setbeamercolor{enumerate item}{fg=cmcmsuRed}%
    \setbeamercolor{enumerate subitem}{fg=cmcmsuRed}%
    \setbeamercolor{enumerate subsubitem}{fg=cmcmsuRed}%
}
