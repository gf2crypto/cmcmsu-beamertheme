% sty/cmcmsu-beamer.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cmcmsu-beamer}[2026/03/01 cmcmsu beamer base]

\RequirePackage{\cmcmsuRoot sty/cmcmsu-options}
\RequirePackage{\cmcmsuRoot sty/cmcmsu-colors}

\mode<presentation>{
    \usetheme{boxes}
    \usecolortheme{lily}
}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}[numbered]

\setbeamercolor{structure}{fg=cmcmsuRed}

\hypersetup{
    colorlinks=true,
    linkcolor=structure.fg,
    filecolor=structure.fg,
    runcolor=structure.fg,
    urlcolor=structure.fg,
    citecolor=structure.fg,
    pdfpagemode=FullScreen
}
\urlstyle{same}

% Dash itemize markers
\newlength{\cmcmsu@dashitemwidth}
\setlength{\cmcmsu@dashitemwidth}{1.8ex}

\setbeamertemplate{itemize item}{%
    \usebeamercolor[fg]{itemize item}%
    \makebox[\cmcmsu@dashitemwidth][l]{\raisebox{0.1ex}{\textendash}}%
}
\setbeamertemplate{itemize subitem}{%
    \usebeamercolor[fg]{itemize subitem}%
    \makebox[\cmcmsu@dashitemwidth][l]{\raisebox{0.1ex}{\textendash}}%
}
\setbeamertemplate{itemize subsubitem}{%
    \usebeamercolor[fg]{itemize subsubitem}%
    \makebox[\cmcmsu@dashitemwidth][l]{\raisebox{0.1ex}{\textendash}}%
}

% Corner logo (optional) from images/
\ifcmcmsu@cornerlogo
    \logo{%
        \IfFileExists{\cmcmsuRoot images/msu-cmc-logo2.png}{%
            \raisebox{-0.4cm}{\includegraphics[height=1cm]{msu-cmc-logo2.png}}%
        }{}%
    }
\fi
